{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'ua=\"${npm_config_user_agent:-}\"; if [ -z \"$ua\" ]; then exit 0; fi; case \"$ua\" in npm/*|bun/*) ;; *) echo \"Use npm or bun instead\" >&2; exit 1 ;; esac'",
    "build": "npm run typecheck && npm run --workspaces --if-present build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run --workspaces --if-present typecheck",
    "vercel": "vercel",
    "vercel:deploy": "vercel deploy",
    "vercel:prod": "vercel deploy --prod",
    "vercel:env": "vercel env",
    "vercel:link": "vercel link",
    "vercel:pull": "vercel pull"
  },
  "private": true,
  "devDependencies": {
    "@continuedev/cli": "^1.5.45",
    "@google/gemini-cli": "^0.38.1",
    "@kilocode/cli": "^7.1.4",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@neovate/code": "^0.28.5",
    "@sourcegraph/amp": "^0.0.1774852556-ge9c066",
    "codebuff": "^1.0.638",
    "opencode-ai": "1.3.13",
    "opencode-codebase-index": "^0.6.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "yaml-language-server": "^1.11.0",
    "zod": "^3.25.76"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3",
    "ajv": "^8.17.1",
    "@tootallnate/once": "^3.0.1",
    "undici": "^6.21.1",
    "yaml": "^2.7.1",
    "tar": "^7.5.0",
    "protobufjs": "^7.5.5",
    "basic-ftp": "^5.2.3",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "lodash": "^4.17.24",
    "minimatch": "^10.2.3",
    "path-to-regexp": "^8.3.0",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.13",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "freebuff": "^0.0.27",
    "vercel": "^52.0.0"
  }
}
