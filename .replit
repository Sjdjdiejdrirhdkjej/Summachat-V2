modules = ["nodejs-22", "python-3.12"]

[[artifacts]]
id = "artifacts/api-server"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = "npm ci && NODE_ENV=production npm run typecheck && NODE_ENV=production npm run -w @workspace/chat-ui build && NODE_ENV=production npm run -w @workspace/api-server build"
run = "NODE_ENV=production node artifacts/api-server/dist/index.mjs"

[deployment.health]
startupPath = "/api/healthz"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Dev"
mode = "parallel"
[[workflows.workflow.steps]]
name = "API Server"
terminal = "bash"
command = "cd artifacts/api-server && npm run dev:watch"
[[workflows.workflow.steps]]
name = "Chat UI"
terminal = "bash"
command = "cd artifacts/chat-ui && npm run dev"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["unzipNLS", "chromium", "tmux", "cargo"]

[userenv]

[[ports]]
localPort = 1455
externalPort = 3000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 9889

[[ports]]
localPort = 24918
externalPort = 3003

[[ports]]
localPort = 62345
externalPort = 3002
exposeLocalhost = true
