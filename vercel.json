{
  "installCommand": "npm install",
  "buildCommand": "VITE_ALLOW_SAME_ORIGIN_API=1 npm run -w @workspace/chat-ui build",
  "outputDirectory": "artifacts/chat-ui/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api(?:$|/)).*)",
      "destination": "/index.html"
    }
  ]
}
