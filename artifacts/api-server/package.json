{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node --enable-source-maps ./dist/index.mjs",
    "dev:serve": "node ./dist/index.mjs",
    "dev:watch": "concurrently \"npm run build:watch\" \"npm run dev:serve:watch\"",
    "build": "node ./build.mjs",
    "build:watch": "node ./build.watch.mjs",
    "dev:serve:watch": "node --enable-source-maps --watch ./dist/index.mjs",
    "start": "node ./dist/index.mjs",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "*",
    "@workspace/db": "*",
    "@workspace/integrations-anthropic-ai": "*",
    "@workspace/integrations-gemini-ai": "*",
    "@workspace/integrations-openai-ai-server": "*",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.1",
    "exa-js": "^2.10.1",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.1.4",
    "thread-stream": "3.1.0",
    "vitest": "^3.2.4"
  }
}
