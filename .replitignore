# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# Caches and stores — not needed at runtime
.cache
.local
.pythonlibs

# Dev tooling config
.git
.agents
.claude
.config
.sisyphus
.codemachine
.cursor
.vercel
conductor

# Source code is not needed — we run pre-built bundles
lib/*/src
artifacts/*/src
scripts

# TypeScript build info
*.tsbuildinfo
tsconfig*.json

# Build tooling
artifacts/*/build.mjs

# Mockup sandbox (not deployed)
artifacts/mockup-sandbox

# Source maps for chat-ui (served statically, maps not needed in prod)
artifacts/chat-ui/dist/public/assets/*.map

# Dev-only config files
*.md
.npmrc
bun.lock

# API spec / codegen packages (only needed at build time, not runtime)
lib/api-spec
lib/api-client-react
lib/api-zod

# Integration lib config (bundled into api-server dist; src already excluded by lib/*/src)
lib/integrations-*/package.json
lib/db/drizzle.config.ts
